# =============================================================================
# SGC — Sistema de Gestión Comercial
# Copia este archivo a .env y completa los valores reales.
# NUNCA subas .env al control de versiones.
# =============================================================================

# ──────────────────────────────────────
# OBLIGATORIAS — el servidor NO arranca sin estas
# ──────────────────────────────────────

# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/business_system"

# Mínimo 32 caracteres aleatorios. Generar con:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
#   o con openssl: openssl rand -hex 48
JWT_SECRET=""

# ──────────────────────────────────────
# SMTP — correos de recuperación de contraseña
# ──────────────────────────────────────
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM_EMAIL=""
SMTP_FROM_NAME=""

# ──────────────────────────────────────
# Cloudflare R2 — almacenamiento de archivos
# ──────────────────────────────────────
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_ENDPOINT=""

# ──────────────────────────────────────
# URL pública de la aplicación
# ──────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Sistema de Gestión Comercial Colombia"

# ──────────────────────────────────────
# API Keys para el Agente de IA AURA
# Al menos una es requerida si el agente está habilitado
# ──────────────────────────────────────
OPENAI_API_KEY=""
CLAUDE_API_KEY=""
