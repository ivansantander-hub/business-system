generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["public", "tenant"]
}

// =============================================
// ENUMS
// =============================================

enum CompanyType {
  RESTAURANT
  GYM
  STORE

  @@schema("public")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  CASHIER
  WAITER
  ACCOUNTANT
  TRAINER

  @@schema("public")
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED

  @@schema("tenant")
}

enum OrderType {
  TABLE
  TAKEOUT
  DELIVERY

  @@schema("tenant")
}

enum OrderStatus {
  OPEN
  IN_PROGRESS
  READY
  PAID
  CANCELLED

  @@schema("tenant")
}

enum OrderItemStatus {
  PENDING
  PREPARING
  READY
  DELIVERED
  CANCELLED

  @@schema("tenant")
}

enum InvoiceStatus {
  PAID
  PENDING
  CANCELLED

  @@schema("tenant")
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  CREDIT

  @@schema("tenant")
}

enum MovementType {
  IN
  OUT
  ADJUSTMENT

  @@schema("tenant")
}

enum PurchaseStatus {
  PENDING
  RECEIVED
  CANCELLED

  @@schema("tenant")
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  INCOME
  EXPENSE
  COST

  @@schema("tenant")
}

enum CashSessionStatus {
  OPEN
  CLOSED

  @@schema("tenant")
}

enum GymMemberStatus {
  ACTIVE
  INACTIVE
  SUSPENDED

  @@schema("tenant")
}

enum MembershipStatus {
  ACTIVE
  EXPIRED
  SUSPENDED
  CANCELLED
  FROZEN

  @@schema("tenant")
}

enum MembershipPaymentStatus {
  PAID
  PENDING
  OVERDUE

  @@schema("tenant")
}

enum CheckInType {
  ENTRY
  EXIT

  @@schema("tenant")
}

enum ContractType {
  INDEFINITE
  FIXED
  OBRA_LABOR
  APPRENTICE
  TEMPORARY

  @@schema("tenant")
}

enum SalaryType {
  ORDINARY
  INTEGRAL

  @@schema("tenant")
}

enum PayrollFrequency {
  MONTHLY
  BIWEEKLY
  WEEKLY

  @@schema("tenant")
}

enum PayrollRunStatus {
  DRAFT
  CALCULATED
  APPROVED
  PAID
  CANCELLED

  @@schema("tenant")
}

enum PayrollConceptType {
  EARNING
  DEDUCTION

  @@schema("tenant")
}

enum PayrollItemDetailType {
  EARNING
  DEDUCTION
  EMPLOYER_COST

  @@schema("tenant")
}

enum ElectronicPayrollStatus {
  PENDING
  GENERATED
  SENT
  ACCEPTED
  REJECTED

  @@schema("tenant")
}

enum CheckInMethod {
  MEMBERSHIP
  DAY_PASS
  MANUAL

  @@schema("tenant")
}

enum DayPassStatus {
  ACTIVE
  USED
  EXPIRED

  @@schema("tenant")
}

enum ClassEnrollmentStatus {
  ENROLLED
  ATTENDED
  ABSENT
  CANCELLED

  @@schema("tenant")
}

enum LockerStatus {
  AVAILABLE
  ASSIGNED
  MAINTENANCE

  @@schema("tenant")
}

// =============================================
// PUBLIC SCHEMA — Master / Multi-tenant
// =============================================

model Company {
  id         String      @id @default(uuid())
  name       String
  legalName  String?     @map("legal_name")
  nit        String      @unique
  type       CompanyType @default(RESTAURANT)
  address    String?
  city       String?
  department String?
  phone      String?
  email      String?
  logoUrl    String?     @map("logo_url")
  taxRegime  String?     @map("tax_regime")
  isActive   Boolean     @default(true) @map("is_active")
  createdAt  DateTime    @default(now()) @map("created_at")

  userCompanies         UserCompany[]
  categories            Category[]
  products              Product[]
  inventoryMoves        InventoryMovement[]
  suppliers             Supplier[]
  purchases             Purchase[]
  customers             Customer[]
  restaurantTables      RestaurantTable[]
  orders                Order[]
  invoices              Invoice[]
  cashSessions          CashSession[]
  accounts              Account[]
  journalEntries        JournalEntry[]
  expenses              Expense[]
  settings              Setting[]
  membershipPlans       MembershipPlan[]
  gymMembers            GymMember[]
  dayPasses             DayPass[]
  gymClasses            GymClass[]
  lockers               Locker[]
  notificationTemplates NotificationTemplate[]
  userNotifPreferences  UserNotificationPreference[]
  rolePermissions       RolePermission[]
  creditNotes           CreditNote[]
  debitNotes            DebitNote[]
  branches              Branch[]
  notifications         Notification[]
  conversations         Conversation[]
  employees             Employee[]
  payrollConfigs        PayrollConfig[]
  payrollConcepts       PayrollConcept[]
  payrollRuns           PayrollRun[]
  payrollProvisions     PayrollProvision[]

  retentionYears             Int     @default(5) @map("retention_years")
  dianResolution             String? @map("dian_resolution")
  dianPrefix                 String? @map("dian_prefix")
  dianRangeFrom              Int?    @map("dian_range_from")
  dianRangeTo                Int?    @map("dian_range_to")
  economicActivity           String? @map("economic_activity")
  taxResponsibilities        String? @map("tax_responsibilities")
  electronicInvoicingEnabled Boolean @default(false) @map("electronic_invoicing_enabled")
  dianTechnicalKey           String? @map("dian_technical_key")
  dianEnvironment            String? @map("dian_environment")
  dianSoftwareId             String? @map("dian_software_id")
  dianSoftwarePin            String? @map("dian_software_pin")
  dianTestSetId              String? @map("dian_test_set_id")

  eInvoiceProvider       String? @map("e_invoice_provider")
  eInvoiceProviderApiUrl String? @map("e_invoice_provider_api_url")
  eInvoiceProviderApiKey String? @map("e_invoice_provider_api_key")
  eInvoiceProviderUser   String? @map("e_invoice_provider_user")
  eInvoiceProviderPass   String? @map("e_invoice_provider_pass")

  electronicPayrollEnabled Boolean @default(false) @map("electronic_payroll_enabled")
  payrollProvider          String? @map("payroll_provider")
  payrollProviderApiUrl    String? @map("payroll_provider_api_url")
  payrollProviderApiKey    String? @map("payroll_provider_api_key")
  payrollProviderUser      String? @map("payroll_provider_user")
  payrollProviderPass      String? @map("payroll_provider_pass")

  @@map("companies")
  @@schema("public")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(CASHIER)
  avatarUrl String?  @map("avatar_url")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  companies               UserCompany[]
  orders                  Order[]                      @relation("OrderUser")
  waiterOrders            Order[]                      @relation("OrderWaiter")
  invoices                Invoice[]
  cashSessions            CashSession[]
  purchases               Purchase[]
  expenses                Expense[]
  inventoryMoves          InventoryMovement[]
  trainerClasses          GymClass[]
  bodyMeasurements        BodyMeasurement[]            @relation("MeasuredBy")
  passwordResetTokens     PasswordResetToken[]
  notificationPreferences UserNotificationPreference[]
  userBranches            UserBranch[]
  userNotifications       UserNotification[]
  conversationParts       ConversationParticipant[]
  sentMessages            Message[]
  employees               Employee[]

  @@map("users")
  @@schema("public")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String    @unique
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@map("password_reset_tokens")
  @@schema("public")
}

model UserCompany {
  id        String  @id @default(uuid())
  userId    String  @map("user_id")
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId String  @map("company_id")
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  role      Role    @default(CASHIER)

  @@unique([userId, companyId])
  @@map("user_companies")
  @@schema("public")
}

// =============================================
// TENANT SCHEMA — Company-scoped business data
// =============================================

model Category {
  id          String     @id @default(uuid())
  companyId   String     @map("company_id")
  company     Company    @relation(fields: [companyId], references: [id])
  name        String
  description String?
  parentId    String?    @map("parent_id")
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryTree")
  products    Product[]

  @@map("categories")
  @@schema("tenant")
}

model Product {
  id          String    @id @default(uuid())
  companyId   String    @map("company_id")
  company     Company   @relation(fields: [companyId], references: [id])
  branchId    String?   @map("branch_id")
  branch      Branch?   @relation(fields: [branchId], references: [id])
  categoryId  String?   @map("category_id")
  category    Category? @relation(fields: [categoryId], references: [id])
  name        String
  description String?
  barcode     String?   @unique
  unit        String    @default("unidad")
  costPrice   Decimal   @default(0) @map("cost_price")
  salePrice   Decimal   @default(0) @map("sale_price")
  taxRate     Decimal   @default(0.19) @map("tax_rate")
  stock       Decimal   @default(0)
  minStock    Decimal   @default(5) @map("min_stock")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")

  orderItems     OrderItem[]
  invoiceItems   InvoiceItem[]
  purchaseItems  PurchaseItem[]
  inventoryMoves InventoryMovement[]

  @@map("products")
  @@schema("tenant")
}

model InventoryMovement {
  id            String       @id @default(uuid())
  companyId     String       @map("company_id")
  company       Company      @relation(fields: [companyId], references: [id])
  branchId      String?      @map("branch_id")
  branch        Branch?      @relation(fields: [branchId], references: [id])
  productId     String       @map("product_id")
  product       Product      @relation(fields: [productId], references: [id])
  userId        String       @map("user_id")
  user          User         @relation(fields: [userId], references: [id])
  type          MovementType
  quantity      Decimal
  previousStock Decimal      @map("previous_stock")
  newStock      Decimal      @map("new_stock")
  reason        String?
  referenceId   String?      @map("reference_id")
  referenceType String?      @map("reference_type")
  createdAt     DateTime     @default(now()) @map("created_at")

  @@map("inventory_movements")
  @@schema("tenant")
}

model Supplier {
  id          String     @id @default(uuid())
  companyId   String     @map("company_id")
  company     Company    @relation(fields: [companyId], references: [id])
  name        String
  nit         String?
  contactName String?    @map("contact_name")
  phone       String?
  email       String?
  address     String?
  isActive    Boolean    @default(true) @map("is_active")
  createdAt   DateTime   @default(now()) @map("created_at")
  purchases   Purchase[]

  @@map("suppliers")
  @@schema("tenant")
}

model Purchase {
  id           String         @id @default(uuid())
  companyId    String         @map("company_id")
  company      Company        @relation(fields: [companyId], references: [id])
  branchId     String?        @map("branch_id")
  branch       Branch?        @relation(fields: [branchId], references: [id])
  supplierId   String         @map("supplier_id")
  supplier     Supplier       @relation(fields: [supplierId], references: [id])
  userId       String         @map("user_id")
  user         User           @relation(fields: [userId], references: [id])
  number       String         @unique
  date         DateTime       @default(now())
  expectedDate DateTime?      @map("expected_date")
  subtotal     Decimal        @default(0)
  tax          Decimal        @default(0)
  total        Decimal        @default(0)
  status       PurchaseStatus @default(PENDING)
  notes        String?
  createdAt    DateTime       @default(now()) @map("created_at")
  items        PurchaseItem[]

  @@map("purchases")
  @@schema("tenant")
}

model PurchaseItem {
  id         String   @id @default(uuid())
  purchaseId String   @map("purchase_id")
  purchase   Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  productId  String   @map("product_id")
  product    Product  @relation(fields: [productId], references: [id])
  quantity   Decimal
  unitPrice  Decimal  @map("unit_price")
  total      Decimal

  @@map("purchase_items")
  @@schema("tenant")
}

model Customer {
  id          String     @id @default(uuid())
  companyId   String     @map("company_id")
  company     Company    @relation(fields: [companyId], references: [id])
  name        String
  nit         String?
  phone       String?
  email       String?
  address     String?
  creditLimit Decimal    @default(0) @map("credit_limit")
  balance     Decimal    @default(0)
  isActive    Boolean    @default(true) @map("is_active")
  createdAt   DateTime   @default(now()) @map("created_at")
  orders      Order[]
  invoices    Invoice[]
  gymMember   GymMember?

  @@map("customers")
  @@schema("tenant")
}

model RestaurantTable {
  id        String      @id @default(uuid())
  companyId String      @map("company_id")
  company   Company     @relation(fields: [companyId], references: [id])
  branchId  String?     @map("branch_id")
  branch    Branch?     @relation(fields: [branchId], references: [id])
  number    String
  capacity  Int         @default(4)
  section   String?
  status    TableStatus @default(AVAILABLE)
  orders    Order[]

  @@unique([companyId, number])
  @@map("restaurant_tables")
  @@schema("tenant")
}

model Order {
  id         String           @id @default(uuid())
  companyId  String           @map("company_id")
  company    Company          @relation(fields: [companyId], references: [id])
  branchId   String?          @map("branch_id")
  branch     Branch?          @relation(fields: [branchId], references: [id])
  tableId    String?          @map("table_id")
  table      RestaurantTable? @relation(fields: [tableId], references: [id])
  customerId String?          @map("customer_id")
  customer   Customer?        @relation(fields: [customerId], references: [id])
  userId     String           @map("user_id")
  user       User             @relation("OrderUser", fields: [userId], references: [id])
  waiterId   String?          @map("waiter_id")
  waiter     User?            @relation("OrderWaiter", fields: [waiterId], references: [id])
  type       OrderType        @default(TABLE)
  status     OrderStatus      @default(OPEN)
  subtotal   Decimal          @default(0)
  tax        Decimal          @default(0)
  discount   Decimal          @default(0)
  total      Decimal          @default(0)
  notes      String?
  createdAt  DateTime         @default(now()) @map("created_at")
  updatedAt  DateTime         @updatedAt @map("updated_at")
  items      OrderItem[]
  invoices   Invoice[]

  @@map("orders")
  @@schema("tenant")
}

model OrderItem {
  id        String          @id @default(uuid())
  orderId   String          @map("order_id")
  order     Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String          @map("product_id")
  product   Product         @relation(fields: [productId], references: [id])
  quantity  Decimal
  unitPrice Decimal         @map("unit_price")
  total     Decimal
  status    OrderItemStatus @default(PENDING)
  notes     String?

  @@map("order_items")
  @@schema("tenant")
}

model Invoice {
  id                  String        @id @default(uuid())
  companyId           String        @map("company_id")
  company             Company       @relation(fields: [companyId], references: [id])
  branchId            String?       @map("branch_id")
  branch              Branch?       @relation(fields: [branchId], references: [id])
  orderId             String?       @map("order_id")
  order               Order?        @relation(fields: [orderId], references: [id])
  customerId          String?       @map("customer_id")
  customer            Customer?     @relation(fields: [customerId], references: [id])
  userId              String        @map("user_id")
  user                User          @relation(fields: [userId], references: [id])
  cashSessionId       String?       @map("cash_session_id")
  cashSession         CashSession?  @relation(fields: [cashSessionId], references: [id])
  number              String
  date                DateTime      @default(now())
  subtotal            Decimal       @default(0)
  taxRate             Decimal       @default(0.19) @map("tax_rate")
  tax                 Decimal       @default(0)
  discount            Decimal       @default(0)
  total               Decimal       @default(0)
  paidAmount          Decimal       @default(0) @map("paid_amount")
  changeAmount        Decimal       @default(0) @map("change_amount")
  paymentMethod       PaymentMethod @default(CASH) @map("payment_method")
  status              InvoiceStatus @default(PAID)
  notes               String?
  createdAt           DateTime      @default(now()) @map("created_at")
  cufe                String?
  qrCode              String?       @map("qr_code")
  dianStatus          String?       @map("dian_status")
  dianResponseDate    DateTime?     @map("dian_response_date")
  dianResponseMessage String?       @map("dian_response_message")
  xmlPath             String?       @map("xml_path")
  items               InvoiceItem[]
  creditNotes         CreditNote[]
  debitNotes          DebitNote[]

  @@unique([companyId, number])
  @@map("invoices")
  @@schema("tenant")
}

model InvoiceItem {
  id          String   @id @default(uuid())
  invoiceId   String   @map("invoice_id")
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  productId   String?  @map("product_id")
  product     Product? @relation(fields: [productId], references: [id])
  productName String   @map("product_name")
  quantity    Decimal
  unitPrice   Decimal  @map("unit_price")
  total       Decimal

  @@map("invoice_items")
  @@schema("tenant")
}

model CashSession {
  id             String            @id @default(uuid())
  companyId      String            @map("company_id")
  company        Company           @relation(fields: [companyId], references: [id])
  branchId       String?           @map("branch_id")
  branch         Branch?           @relation(fields: [branchId], references: [id])
  userId         String            @map("user_id")
  user           User              @relation(fields: [userId], references: [id])
  openingAmount  Decimal           @default(0) @map("opening_amount")
  closingAmount  Decimal?          @map("closing_amount")
  expectedAmount Decimal?          @map("expected_amount")
  difference     Decimal?
  salesTotal     Decimal           @default(0) @map("sales_total")
  openedAt       DateTime          @default(now()) @map("opened_at")
  closedAt       DateTime?         @map("closed_at")
  status         CashSessionStatus @default(OPEN)
  invoices       Invoice[]

  @@map("cash_sessions")
  @@schema("tenant")
}

model Account {
  id           String        @id @default(uuid())
  companyId    String        @map("company_id")
  company      Company       @relation(fields: [companyId], references: [id])
  code         String
  name         String
  type         AccountType
  parentId     String?       @map("parent_id")
  parent       Account?      @relation("AccountTree", fields: [parentId], references: [id])
  children     Account[]     @relation("AccountTree")
  balance      Decimal       @default(0)
  isActive     Boolean       @default(true) @map("is_active")
  journalLines JournalLine[]

  @@unique([companyId, code])
  @@map("accounts")
  @@schema("tenant")
}

model JournalEntry {
  id          String        @id @default(uuid())
  companyId   String        @map("company_id")
  company     Company       @relation(fields: [companyId], references: [id])
  branchId    String?       @map("branch_id")
  branch      Branch?       @relation(fields: [branchId], references: [id])
  date        DateTime      @default(now())
  description String
  reference   String?
  createdAt   DateTime      @default(now()) @map("created_at")
  lines       JournalLine[]

  @@map("journal_entries")
  @@schema("tenant")
}

model JournalLine {
  id          String       @id @default(uuid())
  entryId     String       @map("entry_id")
  entry       JournalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  accountId   String       @map("account_id")
  account     Account      @relation(fields: [accountId], references: [id])
  debit       Decimal      @default(0)
  credit      Decimal      @default(0)
  description String?

  @@map("journal_lines")
  @@schema("tenant")
}

model Expense {
  id            String        @id @default(uuid())
  companyId     String        @map("company_id")
  company       Company       @relation(fields: [companyId], references: [id])
  branchId      String?       @map("branch_id")
  branch        Branch?       @relation(fields: [branchId], references: [id])
  category      String
  description   String
  amount        Decimal
  date          DateTime      @default(now())
  paymentMethod PaymentMethod @default(CASH) @map("payment_method")
  userId        String        @map("user_id")
  user          User          @relation(fields: [userId], references: [id])
  receiptNumber String?       @map("receipt_number")
  notes         String?
  createdAt     DateTime      @default(now()) @map("created_at")

  @@map("expenses")
  @@schema("tenant")
}

model Setting {
  id        String  @id @default(uuid())
  companyId String  @map("company_id")
  company   Company @relation(fields: [companyId], references: [id])
  key       String
  value     String

  @@unique([companyId, key])
  @@map("settings")
  @@schema("tenant")
}

// =============================================
// RBAC — Per-company role permission overrides
// =============================================

model RolePermission {
  id         String  @id @default(uuid())
  companyId  String  @map("company_id")
  company    Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  role       String
  permission String
  enabled    Boolean @default(true)

  @@unique([companyId, role, permission])
  @@map("role_permissions")
  @@schema("tenant")
}

// =============================================
// NOTIFICATION SYSTEM
// =============================================

model NotificationTemplate {
  id        String  @id @default(uuid())
  companyId String  @map("company_id")
  company   Company @relation(fields: [companyId], references: [id])
  eventType String  @map("event_type")
  enabled   Boolean @default(true)
  subject   String?
  bodyHtml  String? @map("body_html")

  @@unique([companyId, eventType])
  @@map("notification_templates")
  @@schema("tenant")
}

model UserNotificationPreference {
  id        String  @id @default(uuid())
  userId    String  @map("user_id")
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId String  @map("company_id")
  company   Company @relation(fields: [companyId], references: [id])
  eventType String  @map("event_type")
  enabled   Boolean @default(true)

  @@unique([userId, companyId, eventType])
  @@map("user_notification_preferences")
  @@schema("tenant")
}

// =============================================
// GYM MODULE
// =============================================

model MembershipPlan {
  id           String   @id @default(uuid())
  companyId    String   @map("company_id")
  company      Company  @relation(fields: [companyId], references: [id])
  name         String
  durationDays Int      @map("duration_days")
  price        Decimal
  description  String?
  features     String?
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")

  memberships Membership[]

  @@map("membership_plans")
  @@schema("tenant")
}

model GymMember {
  id               String          @id @default(uuid())
  companyId        String          @map("company_id")
  company          Company         @relation(fields: [companyId], references: [id])
  customerId       String          @unique @map("customer_id")
  customer         Customer        @relation(fields: [customerId], references: [id])
  emergencyContact String?         @map("emergency_contact")
  emergencyPhone   String?         @map("emergency_phone")
  birthDate        DateTime?       @map("birth_date")
  gender           String?
  bloodType        String?         @map("blood_type")
  medicalNotes     String?         @map("medical_notes")
  photoUrl         String?         @map("photo_url")
  status           GymMemberStatus @default(ACTIVE)
  createdAt        DateTime        @default(now()) @map("created_at")

  memberships       Membership[]
  checkIns          CheckIn[]
  dayPasses         DayPass[]
  classEnrollments  ClassEnrollment[]
  bodyMeasurements  BodyMeasurement[]
  lockerAssignments LockerAssignment[]

  @@unique([companyId, customerId])
  @@map("gym_members")
  @@schema("tenant")
}

model Membership {
  id            String                  @id @default(uuid())
  companyId     String                  @map("company_id")
  memberId      String                  @map("member_id")
  member        GymMember               @relation(fields: [memberId], references: [id])
  planId        String                  @map("plan_id")
  plan          MembershipPlan          @relation(fields: [planId], references: [id])
  startDate     DateTime                @map("start_date")
  endDate       DateTime                @map("end_date")
  status        MembershipStatus        @default(ACTIVE)
  paymentStatus MembershipPaymentStatus @default(PENDING) @map("payment_status")
  invoiceId     String?                 @map("invoice_id")
  notes         String?
  createdAt     DateTime                @default(now()) @map("created_at")

  @@map("memberships")
  @@schema("tenant")
}

model CheckIn {
  id        String        @id @default(uuid())
  companyId String        @map("company_id")
  memberId  String        @map("member_id")
  member    GymMember     @relation(fields: [memberId], references: [id])
  timestamp DateTime      @default(now())
  type      CheckInType
  method    CheckInMethod
  dayPassId String?       @map("day_pass_id")
  notes     String?

  @@map("check_ins")
  @@schema("tenant")
}

model DayPass {
  id           String        @id @default(uuid())
  companyId    String        @map("company_id")
  company      Company       @relation(fields: [companyId], references: [id])
  memberId     String?       @map("member_id")
  member       GymMember?    @relation(fields: [memberId], references: [id])
  guestName    String?       @map("guest_name")
  date         DateTime      @default(now())
  price        Decimal
  totalEntries Int           @default(1) @map("total_entries")
  usedEntries  Int           @default(0) @map("used_entries")
  status       DayPassStatus @default(ACTIVE)
  invoiceId    String?       @map("invoice_id")
  createdAt    DateTime      @default(now()) @map("created_at")

  @@map("day_passes")
  @@schema("tenant")
}

model GymClass {
  id          String   @id @default(uuid())
  companyId   String   @map("company_id")
  company     Company  @relation(fields: [companyId], references: [id])
  name        String
  description String?
  trainerId   String?  @map("trainer_id")
  trainer     User?    @relation(fields: [trainerId], references: [id])
  dayOfWeek   Int      @map("day_of_week")
  startTime   String   @map("start_time")
  endTime     String   @map("end_time")
  maxCapacity Int      @default(20) @map("max_capacity")
  room        String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  enrollments ClassEnrollment[]

  @@map("gym_classes")
  @@schema("tenant")
}

model ClassEnrollment {
  id        String                @id @default(uuid())
  companyId String                @map("company_id")
  memberId  String                @map("member_id")
  member    GymMember             @relation(fields: [memberId], references: [id])
  classId   String                @map("class_id")
  gymClass  GymClass              @relation(fields: [classId], references: [id])
  date      DateTime
  status    ClassEnrollmentStatus @default(ENROLLED)

  @@map("class_enrollments")
  @@schema("tenant")
}

model BodyMeasurement {
  id           String    @id @default(uuid())
  companyId    String    @map("company_id")
  memberId     String    @map("member_id")
  member       GymMember @relation(fields: [memberId], references: [id])
  date         DateTime  @default(now())
  weight       Decimal?
  height       Decimal?
  bodyFat      Decimal?  @map("body_fat")
  chest        Decimal?
  waist        Decimal?
  hips         Decimal?
  leftArm      Decimal?  @map("left_arm")
  rightArm     Decimal?  @map("right_arm")
  leftThigh    Decimal?  @map("left_thigh")
  rightThigh   Decimal?  @map("right_thigh")
  notes        String?
  measuredById String?   @map("measured_by_id")
  measuredBy   User?     @relation("MeasuredBy", fields: [measuredById], references: [id])

  @@map("body_measurements")
  @@schema("tenant")
}

// =============================================
// CREDIT / DEBIT NOTES (DIAN Preparation)
// =============================================

model CreditNote {
  id        String   @id @default(uuid())
  companyId String   @map("company_id")
  company   Company  @relation(fields: [companyId], references: [id])
  invoiceId String   @map("invoice_id")
  invoice   Invoice  @relation(fields: [invoiceId], references: [id])
  userId    String   @map("user_id")
  number    String
  date      DateTime @default(now())
  reason    String
  subtotal  Decimal
  tax       Decimal
  total     Decimal
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([companyId, number])
  @@map("credit_notes")
  @@schema("tenant")
}

model DebitNote {
  id        String   @id @default(uuid())
  companyId String   @map("company_id")
  company   Company  @relation(fields: [companyId], references: [id])
  invoiceId String   @map("invoice_id")
  invoice   Invoice  @relation(fields: [invoiceId], references: [id])
  userId    String   @map("user_id")
  number    String
  date      DateTime @default(now())
  reason    String
  subtotal  Decimal
  tax       Decimal
  total     Decimal
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([companyId, number])
  @@map("debit_notes")
  @@schema("tenant")
}

// =============================================
// AUDIT LOG
// =============================================

model AuditLog {
  id           String   @id @default(uuid())
  companyId    String?  @map("company_id")
  userId       String?  @map("user_id")
  userName     String?  @map("user_name")
  action       String
  entity       String?
  entityId     String?  @map("entity_id")
  details      Json?
  beforeState  Json?    @map("before_state")
  afterState   Json?    @map("after_state")
  changeReason String?  @map("change_reason")
  checksum     String?
  ipAddress    String?  @map("ip_address")
  userAgent    String?  @map("user_agent")
  source       String   @default("backend")
  level        String   @default("info")
  duration     Int?
  statusCode   Int?     @map("status_code")
  path         String?
  method       String?
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([companyId, createdAt])
  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
  @@schema("public")
}

model Locker {
  id        String       @id @default(uuid())
  companyId String       @map("company_id")
  company   Company      @relation(fields: [companyId], references: [id])
  number    String
  section   String?
  status    LockerStatus @default(AVAILABLE)

  assignments LockerAssignment[]

  @@unique([companyId, number])
  @@map("lockers")
  @@schema("tenant")
}

model LockerAssignment {
  id         String    @id @default(uuid())
  companyId  String    @map("company_id")
  lockerId   String    @map("locker_id")
  locker     Locker    @relation(fields: [lockerId], references: [id])
  memberId   String    @map("member_id")
  member     GymMember @relation(fields: [memberId], references: [id])
  startDate  DateTime  @map("start_date")
  endDate    DateTime? @map("end_date")
  monthlyFee Decimal   @default(0) @map("monthly_fee")

  @@map("locker_assignments")
  @@schema("tenant")
}

// =============================================
// BRANCHES (SUCURSALES)
// =============================================

model Branch {
  id        String   @id @default(uuid())
  companyId String   @map("company_id")
  company   Company  @relation(fields: [companyId], references: [id])
  name      String
  address   String?
  city      String?
  phone     String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  users            UserBranch[]
  products         Product[]
  invoices         Invoice[]
  orders           Order[]
  cashSessions     CashSession[]
  purchases        Purchase[]
  inventoryMoves   InventoryMovement[]
  expenses         Expense[]
  restaurantTables RestaurantTable[]
  journalEntries   JournalEntry[]
  employees        Employee[]
  payrollRuns      PayrollRun[]

  @@map("branches")
  @@schema("tenant")
}

model UserBranch {
  id       String @id @default(uuid())
  userId   String @map("user_id")
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  branchId String @map("branch_id")
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([userId, branchId])
  @@map("user_branches")
  @@schema("tenant")
}

// =============================================
// NOTIFICATIONS (stored emails / system alerts)
// =============================================

model Notification {
  id        String   @id @default(uuid())
  companyId String   @map("company_id")
  company   Company  @relation(fields: [companyId], references: [id])
  type      String   @default("email")
  subject   String
  bodyHtml  String?  @map("body_html")
  bodyText  String?  @map("body_text")
  eventType String?  @map("event_type")
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  recipients UserNotification[]

  @@index([companyId, createdAt])
  @@map("notifications")
  @@schema("tenant")
}

model UserNotification {
  id             String       @id @default(uuid())
  userId         String       @map("user_id")
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  notificationId String       @map("notification_id")
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  readAt         DateTime?    @map("read_at")
  createdAt      DateTime     @default(now()) @map("created_at")

  @@unique([userId, notificationId])
  @@index([userId, readAt])
  @@map("user_notifications")
  @@schema("tenant")
}

// =============================================
// INTERNAL MESSAGING
// =============================================

model Conversation {
  id        String   @id @default(uuid())
  companyId String   @map("company_id")
  company   Company  @relation(fields: [companyId], references: [id])
  name      String?
  isGroup   Boolean  @default(false) @map("is_group")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  participants ConversationParticipant[]
  messages     Message[]

  @@index([companyId, updatedAt])
  @@map("conversations")
  @@schema("tenant")
}

model ConversationParticipant {
  id             String       @id @default(uuid())
  conversationId String       @map("conversation_id")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String       @map("user_id")
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt       DateTime     @default(now()) @map("joined_at")
  lastReadAt     DateTime?    @map("last_read_at")
  isAdmin        Boolean      @default(false) @map("is_admin")

  @@unique([conversationId, userId])
  @@map("conversation_participants")
  @@schema("tenant")
}

model Message {
  id             String       @id @default(uuid())
  conversationId String       @map("conversation_id")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String       @map("sender_id")
  sender         User         @relation(fields: [senderId], references: [id])
  content        String
  createdAt      DateTime     @default(now()) @map("created_at")
  editedAt       DateTime?    @map("edited_at")

  attachments MessageAttachment[]

  @@index([conversationId, createdAt])
  @@map("messages")
  @@schema("tenant")
}

model MessageAttachment {
  id        String  @id @default(uuid())
  messageId String  @map("message_id")
  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  fileName  String  @map("file_name")
  fileSize  Int     @map("file_size")
  mimeType  String  @map("mime_type")
  r2Key     String  @map("r2_key")

  @@map("message_attachments")
  @@schema("tenant")
}

// =============================================
// PAYROLL / HR MODELS
// =============================================

model Employee {
  id        String  @id @default(uuid())
  companyId String  @map("company_id")
  company   Company @relation(fields: [companyId], references: [id])
  branchId  String? @map("branch_id")
  branch    Branch? @relation(fields: [branchId], references: [id])
  userId    String? @map("user_id")
  user      User?   @relation(fields: [userId], references: [id])

  firstName String    @map("first_name")
  lastName  String    @map("last_name")
  docType   String    @default("CC") @map("doc_type")
  docNumber String    @map("doc_number")
  birthDate DateTime? @map("birth_date")
  address   String?
  email     String?
  phone     String?
  gender    String?

  contractType ContractType @default(INDEFINITE) @map("contract_type")
  startDate    DateTime     @map("start_date")
  endDate      DateTime?    @map("end_date")
  position     String?
  costCenter   String?      @map("cost_center")
  baseSalary   Decimal      @default(0) @map("base_salary") @db.Decimal(18, 2)
  salaryType   SalaryType   @default(ORDINARY) @map("salary_type")
  workSchedule String?      @default("Lunes a Viernes") @map("work_schedule")
  supervisorId String?      @map("supervisor_id")

  bank          String?
  accountType   String? @map("account_type")
  accountNumber String? @map("account_number")
  paymentMethod String? @default("TRANSFER") @map("payment_method")

  dependents          Int     @default(0)
  voluntaryDeductions Decimal @default(0) @map("voluntary_deductions") @db.Decimal(18, 2)
  withholdingRate     Decimal @default(0) @map("withholding_rate") @db.Decimal(8, 4)

  eps              String?
  pensionFund      String? @map("pension_fund")
  arl              String?
  arlRiskLevel     Int     @default(1) @map("arl_risk_level")
  compensationFund String? @map("compensation_fund")

  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  payrollItems PayrollItem[]
  provisions   PayrollProvision[]

  @@unique([companyId, docNumber])
  @@index([companyId])
  @@map("employees")
  @@schema("tenant")
}

model PayrollConfig {
  id        String  @id @default(uuid())
  companyId String  @unique @map("company_id")
  company   Company @relation(fields: [companyId], references: [id])

  minimumWage      Decimal @default(1300000) @map("minimum_wage") @db.Decimal(18, 2)
  transportSubsidy Decimal @default(162000) @map("transport_subsidy") @db.Decimal(18, 2)
  uvtValue         Decimal @default(47065) @map("uvt_value") @db.Decimal(18, 2)

  healthEmployeeRate  Decimal @default(0.04) @map("health_employee_rate") @db.Decimal(8, 4)
  healthEmployerRate  Decimal @default(0.085) @map("health_employer_rate") @db.Decimal(8, 4)
  pensionEmployeeRate Decimal @default(0.04) @map("pension_employee_rate") @db.Decimal(8, 4)
  pensionEmployerRate Decimal @default(0.12) @map("pension_employer_rate") @db.Decimal(8, 4)
  arlRateLevel1       Decimal @default(0.00522) @map("arl_rate_level1") @db.Decimal(8, 5)
  arlRateLevel2       Decimal @default(0.01044) @map("arl_rate_level2") @db.Decimal(8, 5)
  arlRateLevel3       Decimal @default(0.02436) @map("arl_rate_level3") @db.Decimal(8, 5)
  arlRateLevel4       Decimal @default(0.04350) @map("arl_rate_level4") @db.Decimal(8, 5)
  arlRateLevel5       Decimal @default(0.06960) @map("arl_rate_level5") @db.Decimal(8, 5)
  compensationRate    Decimal @default(0.04) @map("compensation_rate") @db.Decimal(8, 4)
  senaRate            Decimal @default(0.02) @map("sena_rate") @db.Decimal(8, 4)
  icbfRate            Decimal @default(0.03) @map("icbf_rate") @db.Decimal(8, 4)

  primaRate             Decimal @default(0.0833) @map("prima_rate") @db.Decimal(8, 4)
  cesantiasRate         Decimal @default(0.0833) @map("cesantias_rate") @db.Decimal(8, 4)
  cesantiasInterestRate Decimal @default(0.12) @map("cesantias_interest_rate") @db.Decimal(8, 4)
  vacationsRate         Decimal @default(0.0417) @map("vacations_rate") @db.Decimal(8, 4)

  solidarityFundThreshold Int     @default(4) @map("solidarity_fund_threshold")
  solidarityFundRate      Decimal @default(0.01) @map("solidarity_fund_rate") @db.Decimal(8, 4)

  payrollFrequency PayrollFrequency @default(MONTHLY) @map("payroll_frequency")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([companyId])
  @@map("payroll_configs")
  @@schema("tenant")
}

model PayrollConcept {
  id          String             @id @default(uuid())
  companyId   String             @map("company_id")
  company     Company            @relation(fields: [companyId], references: [id])
  code        String
  name        String
  type        PayrollConceptType
  subtype     String?
  isAutomatic Boolean            @default(false) @map("is_automatic")
  formula     String?
  rate        Decimal?           @db.Decimal(8, 4)
  isActive    Boolean            @default(true) @map("is_active")
  createdAt   DateTime           @default(now()) @map("created_at")

  details PayrollItemDetail[]

  @@unique([companyId, code])
  @@index([companyId])
  @@map("payroll_concepts")
  @@schema("tenant")
}

model PayrollRun {
  id                 String           @id @default(uuid())
  companyId          String           @map("company_id")
  company            Company          @relation(fields: [companyId], references: [id])
  branchId           String?          @map("branch_id")
  branch             Branch?          @relation(fields: [branchId], references: [id])
  period             DateTime
  periodStart        DateTime         @map("period_start")
  periodEnd          DateTime         @map("period_end")
  frequency          PayrollFrequency @default(MONTHLY)
  status             PayrollRunStatus @default(DRAFT)
  totalEarnings      Decimal          @default(0) @map("total_earnings") @db.Decimal(18, 2)
  totalDeductions    Decimal          @default(0) @map("total_deductions") @db.Decimal(18, 2)
  totalEmployerCosts Decimal          @default(0) @map("total_employer_costs") @db.Decimal(18, 2)
  netPay             Decimal          @default(0) @map("net_pay") @db.Decimal(18, 2)
  notes              String?
  approvedById       String?          @map("approved_by_id")
  approvedAt         DateTime?        @map("approved_at")
  paidAt             DateTime?        @map("paid_at")
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")

  items PayrollItem[]

  @@index([companyId])
  @@map("payroll_runs")
  @@schema("tenant")
}

model PayrollItem {
  id              String     @id @default(uuid())
  payrollRunId    String     @map("payroll_run_id")
  payrollRun      PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  employeeId      String     @map("employee_id")
  employee        Employee   @relation(fields: [employeeId], references: [id])
  baseSalary      Decimal    @default(0) @map("base_salary") @db.Decimal(18, 2)
  daysWorked      Int        @default(30) @map("days_worked")
  totalEarnings   Decimal    @default(0) @map("total_earnings") @db.Decimal(18, 2)
  totalDeductions Decimal    @default(0) @map("total_deductions") @db.Decimal(18, 2)
  employerCosts   Decimal    @default(0) @map("employer_costs") @db.Decimal(18, 2)
  netPay          Decimal    @default(0) @map("net_pay") @db.Decimal(18, 2)
  createdAt       DateTime   @default(now()) @map("created_at")

  details       PayrollItemDetail[]
  electronicDoc ElectronicPayrollDocument?

  @@index([payrollRunId])
  @@index([employeeId])
  @@map("payroll_items")
  @@schema("tenant")
}

model PayrollItemDetail {
  id            String                @id @default(uuid())
  payrollItemId String                @map("payroll_item_id")
  payrollItem   PayrollItem           @relation(fields: [payrollItemId], references: [id], onDelete: Cascade)
  conceptId     String?               @map("concept_id")
  concept       PayrollConcept?       @relation(fields: [conceptId], references: [id])
  conceptCode   String                @map("concept_code")
  conceptName   String                @map("concept_name")
  type          PayrollItemDetailType
  quantity      Decimal               @default(1) @db.Decimal(10, 2)
  rate          Decimal               @default(0) @db.Decimal(8, 4)
  base          Decimal               @default(0) @db.Decimal(18, 2)
  amount        Decimal               @default(0) @db.Decimal(18, 2)

  @@index([payrollItemId])
  @@map("payroll_item_details")
  @@schema("tenant")
}

model PayrollProvision {
  id                      String   @id @default(uuid())
  companyId               String   @map("company_id")
  company                 Company  @relation(fields: [companyId], references: [id])
  employeeId              String   @map("employee_id")
  employee                Employee @relation(fields: [employeeId], references: [id])
  period                  DateTime
  primaAmount             Decimal  @default(0) @map("prima_amount") @db.Decimal(18, 2)
  cesantiasAmount         Decimal  @default(0) @map("cesantias_amount") @db.Decimal(18, 2)
  cesantiasInterestAmount Decimal  @default(0) @map("cesantias_interest_amount") @db.Decimal(18, 2)
  vacationsAmount         Decimal  @default(0) @map("vacations_amount") @db.Decimal(18, 2)
  createdAt               DateTime @default(now()) @map("created_at")

  @@unique([companyId, employeeId, period])
  @@index([companyId])
  @@map("payroll_provisions")
  @@schema("tenant")
}

model ElectronicPayrollDocument {
  id               String                  @id @default(uuid())
  payrollItemId    String                  @unique @map("payroll_item_id")
  payrollItem      PayrollItem             @relation(fields: [payrollItemId], references: [id], onDelete: Cascade)
  cune             String?
  xmlContent       String?                 @map("xml_content")
  dianStatus       ElectronicPayrollStatus @default(PENDING) @map("dian_status")
  dianResponse     Json?                   @map("dian_response")
  providerResponse Json?                   @map("provider_response")
  sentAt           DateTime?               @map("sent_at")
  createdAt        DateTime                @default(now()) @map("created_at")

  @@map("electronic_payroll_documents")
  @@schema("tenant")
}
