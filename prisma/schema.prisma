generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["public", "tenant"]
}

// =============================================
// ENUMS
// =============================================

enum CompanyType {
  RESTAURANT
  GYM

  @@schema("public")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  CASHIER
  WAITER
  ACCOUNTANT
  TRAINER

  @@schema("public")
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED

  @@schema("tenant")
}

enum OrderType {
  TABLE
  TAKEOUT
  DELIVERY

  @@schema("tenant")
}

enum OrderStatus {
  OPEN
  READY
  PAID
  CANCELLED

  @@schema("tenant")
}

enum OrderItemStatus {
  PENDING
  PREPARING
  READY
  DELIVERED
  CANCELLED

  @@schema("tenant")
}

enum InvoiceStatus {
  PAID
  PENDING
  CANCELLED

  @@schema("tenant")
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  CREDIT

  @@schema("tenant")
}

enum MovementType {
  IN
  OUT
  ADJUSTMENT

  @@schema("tenant")
}

enum PurchaseStatus {
  PENDING
  RECEIVED
  CANCELLED

  @@schema("tenant")
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  INCOME
  EXPENSE
  COST

  @@schema("tenant")
}

enum CashSessionStatus {
  OPEN
  CLOSED

  @@schema("tenant")
}

enum GymMemberStatus {
  ACTIVE
  INACTIVE
  SUSPENDED

  @@schema("tenant")
}

enum MembershipStatus {
  ACTIVE
  EXPIRED
  SUSPENDED
  CANCELLED
  FROZEN

  @@schema("tenant")
}

enum MembershipPaymentStatus {
  PAID
  PENDING
  OVERDUE

  @@schema("tenant")
}

enum CheckInType {
  ENTRY
  EXIT

  @@schema("tenant")
}

enum CheckInMethod {
  MEMBERSHIP
  DAY_PASS
  MANUAL

  @@schema("tenant")
}

enum DayPassStatus {
  ACTIVE
  USED
  EXPIRED

  @@schema("tenant")
}

enum ClassEnrollmentStatus {
  ENROLLED
  ATTENDED
  ABSENT
  CANCELLED

  @@schema("tenant")
}

enum LockerStatus {
  AVAILABLE
  ASSIGNED
  MAINTENANCE

  @@schema("tenant")
}

// =============================================
// PUBLIC SCHEMA — Master / Multi-tenant
// =============================================

model Company {
  id         Int         @id @default(autoincrement())
  name       String
  legalName  String?     @map("legal_name")
  nit        String      @unique
  type       CompanyType @default(RESTAURANT)
  address    String?
  city       String?
  department String?
  phone      String?
  email      String?
  taxRegime  String?     @map("tax_regime")
  isActive   Boolean     @default(true) @map("is_active")
  createdAt  DateTime    @default(now()) @map("created_at")

  userCompanies    UserCompany[]
  categories       Category[]
  products         Product[]
  inventoryMoves   InventoryMovement[]
  suppliers        Supplier[]
  purchases        Purchase[]
  customers        Customer[]
  restaurantTables RestaurantTable[]
  orders           Order[]
  invoices         Invoice[]
  cashSessions     CashSession[]
  accounts         Account[]
  journalEntries   JournalEntry[]
  expenses         Expense[]
  settings         Setting[]
  membershipPlans  MembershipPlan[]
  gymMembers       GymMember[]
  dayPasses        DayPass[]
  gymClasses       GymClass[]
  lockers          Locker[]

  @@schema("public")
  @@map("companies")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(CASHIER)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  companies        UserCompany[]
  orders           Order[]             @relation("OrderUser")
  waiterOrders     Order[]             @relation("OrderWaiter")
  invoices         Invoice[]
  cashSessions     CashSession[]
  purchases        Purchase[]
  expenses         Expense[]
  inventoryMoves   InventoryMovement[]
  trainerClasses   GymClass[]
  bodyMeasurements BodyMeasurement[]   @relation("MeasuredBy")

  @@schema("public")
  @@map("users")
}

model UserCompany {
  id        Int     @id @default(autoincrement())
  userId    Int     @map("user_id")
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId Int     @map("company_id")
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  role      Role    @default(CASHIER)

  @@unique([userId, companyId])
  @@schema("public")
  @@map("user_companies")
}

// =============================================
// TENANT SCHEMA — Company-scoped business data
// =============================================

model Category {
  id          Int        @id @default(autoincrement())
  companyId   Int        @map("company_id")
  company     Company    @relation(fields: [companyId], references: [id])
  name        String
  description String?
  parentId    Int?       @map("parent_id")
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryTree")
  products    Product[]

  @@schema("tenant")
  @@map("categories")
}

model Product {
  id          Int       @id @default(autoincrement())
  companyId   Int       @map("company_id")
  company     Company   @relation(fields: [companyId], references: [id])
  categoryId  Int?      @map("category_id")
  category    Category? @relation(fields: [categoryId], references: [id])
  name        String
  description String?
  barcode     String?   @unique
  unit        String    @default("unidad")
  costPrice   Decimal   @default(0) @map("cost_price")
  salePrice   Decimal   @default(0) @map("sale_price")
  taxRate     Decimal   @default(0.19) @map("tax_rate")
  stock       Decimal   @default(0)
  minStock    Decimal   @default(5) @map("min_stock")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")

  orderItems     OrderItem[]
  invoiceItems   InvoiceItem[]
  purchaseItems  PurchaseItem[]
  inventoryMoves InventoryMovement[]

  @@schema("tenant")
  @@map("products")
}

model InventoryMovement {
  id            Int          @id @default(autoincrement())
  companyId     Int          @map("company_id")
  company       Company      @relation(fields: [companyId], references: [id])
  productId     Int          @map("product_id")
  product       Product      @relation(fields: [productId], references: [id])
  userId        Int          @map("user_id")
  user          User         @relation(fields: [userId], references: [id])
  type          MovementType
  quantity      Decimal
  previousStock Decimal      @map("previous_stock")
  newStock      Decimal      @map("new_stock")
  reason        String?
  referenceId   Int?         @map("reference_id")
  referenceType String?      @map("reference_type")
  createdAt     DateTime     @default(now()) @map("created_at")

  @@schema("tenant")
  @@map("inventory_movements")
}

model Supplier {
  id          Int        @id @default(autoincrement())
  companyId   Int        @map("company_id")
  company     Company    @relation(fields: [companyId], references: [id])
  name        String
  nit         String?
  contactName String?    @map("contact_name")
  phone       String?
  email       String?
  address     String?
  isActive    Boolean    @default(true) @map("is_active")
  createdAt   DateTime   @default(now()) @map("created_at")
  purchases   Purchase[]

  @@schema("tenant")
  @@map("suppliers")
}

model Purchase {
  id           Int            @id @default(autoincrement())
  companyId    Int            @map("company_id")
  company      Company        @relation(fields: [companyId], references: [id])
  supplierId   Int            @map("supplier_id")
  supplier     Supplier       @relation(fields: [supplierId], references: [id])
  userId       Int            @map("user_id")
  user         User           @relation(fields: [userId], references: [id])
  number       String         @unique
  date         DateTime       @default(now())
  expectedDate DateTime?      @map("expected_date")
  subtotal     Decimal        @default(0)
  tax          Decimal        @default(0)
  total        Decimal        @default(0)
  status       PurchaseStatus @default(PENDING)
  notes        String?
  createdAt    DateTime       @default(now()) @map("created_at")
  items        PurchaseItem[]

  @@schema("tenant")
  @@map("purchases")
}

model PurchaseItem {
  id         Int      @id @default(autoincrement())
  purchaseId Int      @map("purchase_id")
  purchase   Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  productId  Int      @map("product_id")
  product    Product  @relation(fields: [productId], references: [id])
  quantity   Decimal
  unitPrice  Decimal  @map("unit_price")
  total      Decimal

  @@schema("tenant")
  @@map("purchase_items")
}

model Customer {
  id          Int        @id @default(autoincrement())
  companyId   Int        @map("company_id")
  company     Company    @relation(fields: [companyId], references: [id])
  name        String
  nit         String?
  phone       String?
  email       String?
  address     String?
  creditLimit Decimal    @default(0) @map("credit_limit")
  balance     Decimal    @default(0)
  isActive    Boolean    @default(true) @map("is_active")
  createdAt   DateTime   @default(now()) @map("created_at")
  orders      Order[]
  invoices    Invoice[]
  gymMember   GymMember?

  @@schema("tenant")
  @@map("customers")
}

model RestaurantTable {
  id        Int         @id @default(autoincrement())
  companyId Int         @map("company_id")
  company   Company     @relation(fields: [companyId], references: [id])
  number    String
  capacity  Int         @default(4)
  section   String?
  status    TableStatus @default(AVAILABLE)
  orders    Order[]

  @@unique([companyId, number])
  @@schema("tenant")
  @@map("restaurant_tables")
}

model Order {
  id         Int              @id @default(autoincrement())
  companyId  Int              @map("company_id")
  company    Company          @relation(fields: [companyId], references: [id])
  tableId    Int?             @map("table_id")
  table      RestaurantTable? @relation(fields: [tableId], references: [id])
  customerId Int?             @map("customer_id")
  customer   Customer?        @relation(fields: [customerId], references: [id])
  userId     Int              @map("user_id")
  user       User             @relation("OrderUser", fields: [userId], references: [id])
  waiterId   Int?             @map("waiter_id")
  waiter     User?            @relation("OrderWaiter", fields: [waiterId], references: [id])
  type       OrderType        @default(TABLE)
  status     OrderStatus      @default(OPEN)
  subtotal   Decimal          @default(0)
  tax        Decimal          @default(0)
  discount   Decimal          @default(0)
  total      Decimal          @default(0)
  notes      String?
  createdAt  DateTime         @default(now()) @map("created_at")
  updatedAt  DateTime         @updatedAt @map("updated_at")
  items      OrderItem[]
  invoices   Invoice[]

  @@schema("tenant")
  @@map("orders")
}

model OrderItem {
  id        Int             @id @default(autoincrement())
  orderId   Int             @map("order_id")
  order     Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId Int             @map("product_id")
  product   Product         @relation(fields: [productId], references: [id])
  quantity  Decimal
  unitPrice Decimal         @map("unit_price")
  total     Decimal
  status    OrderItemStatus @default(PENDING)
  notes     String?

  @@schema("tenant")
  @@map("order_items")
}

model Invoice {
  id             Int           @id @default(autoincrement())
  companyId      Int           @map("company_id")
  company        Company       @relation(fields: [companyId], references: [id])
  orderId        Int?          @map("order_id")
  order          Order?        @relation(fields: [orderId], references: [id])
  customerId     Int?          @map("customer_id")
  customer       Customer?     @relation(fields: [customerId], references: [id])
  userId         Int           @map("user_id")
  user           User          @relation(fields: [userId], references: [id])
  cashSessionId  Int?          @map("cash_session_id")
  cashSession    CashSession?  @relation(fields: [cashSessionId], references: [id])
  number         String
  date           DateTime      @default(now())
  subtotal       Decimal       @default(0)
  taxRate        Decimal       @default(0.19) @map("tax_rate")
  tax            Decimal       @default(0)
  discount       Decimal       @default(0)
  total          Decimal       @default(0)
  paidAmount     Decimal       @default(0) @map("paid_amount")
  changeAmount   Decimal       @default(0) @map("change_amount")
  paymentMethod  PaymentMethod @default(CASH) @map("payment_method")
  status         InvoiceStatus @default(PAID)
  notes          String?
  createdAt      DateTime      @default(now()) @map("created_at")
  items          InvoiceItem[]

  @@unique([companyId, number])
  @@schema("tenant")
  @@map("invoices")
}

model InvoiceItem {
  id          Int      @id @default(autoincrement())
  invoiceId   Int      @map("invoice_id")
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  productId   Int?     @map("product_id")
  product     Product? @relation(fields: [productId], references: [id])
  productName String   @map("product_name")
  quantity    Decimal
  unitPrice   Decimal  @map("unit_price")
  total       Decimal

  @@schema("tenant")
  @@map("invoice_items")
}

model CashSession {
  id             Int               @id @default(autoincrement())
  companyId      Int               @map("company_id")
  company        Company           @relation(fields: [companyId], references: [id])
  userId         Int               @map("user_id")
  user           User              @relation(fields: [userId], references: [id])
  openingAmount  Decimal           @default(0) @map("opening_amount")
  closingAmount  Decimal?          @map("closing_amount")
  expectedAmount Decimal?          @map("expected_amount")
  difference     Decimal?
  salesTotal     Decimal           @default(0) @map("sales_total")
  openedAt       DateTime          @default(now()) @map("opened_at")
  closedAt       DateTime?         @map("closed_at")
  status         CashSessionStatus @default(OPEN)
  invoices       Invoice[]

  @@schema("tenant")
  @@map("cash_sessions")
}

model Account {
  id           Int           @id @default(autoincrement())
  companyId    Int           @map("company_id")
  company      Company       @relation(fields: [companyId], references: [id])
  code         String
  name         String
  type         AccountType
  parentId     Int?          @map("parent_id")
  parent       Account?      @relation("AccountTree", fields: [parentId], references: [id])
  children     Account[]     @relation("AccountTree")
  balance      Decimal       @default(0)
  isActive     Boolean       @default(true) @map("is_active")
  journalLines JournalLine[]

  @@unique([companyId, code])
  @@schema("tenant")
  @@map("accounts")
}

model JournalEntry {
  id          Int           @id @default(autoincrement())
  companyId   Int           @map("company_id")
  company     Company       @relation(fields: [companyId], references: [id])
  date        DateTime      @default(now())
  description String
  reference   String?
  createdAt   DateTime      @default(now()) @map("created_at")
  lines       JournalLine[]

  @@schema("tenant")
  @@map("journal_entries")
}

model JournalLine {
  id          Int          @id @default(autoincrement())
  entryId     Int          @map("entry_id")
  entry       JournalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  accountId   Int          @map("account_id")
  account     Account      @relation(fields: [accountId], references: [id])
  debit       Decimal      @default(0)
  credit      Decimal      @default(0)
  description String?

  @@schema("tenant")
  @@map("journal_lines")
}

model Expense {
  id            Int           @id @default(autoincrement())
  companyId     Int           @map("company_id")
  company       Company       @relation(fields: [companyId], references: [id])
  category      String
  description   String
  amount        Decimal
  date          DateTime      @default(now())
  paymentMethod PaymentMethod @default(CASH) @map("payment_method")
  userId        Int           @map("user_id")
  user          User          @relation(fields: [userId], references: [id])
  receiptNumber String?       @map("receipt_number")
  notes         String?
  createdAt     DateTime      @default(now()) @map("created_at")

  @@schema("tenant")
  @@map("expenses")
}

model Setting {
  id        Int     @id @default(autoincrement())
  companyId Int     @map("company_id")
  company   Company @relation(fields: [companyId], references: [id])
  key       String
  value     String

  @@unique([companyId, key])
  @@schema("tenant")
  @@map("settings")
}

// =============================================
// GYM MODULE
// =============================================

model MembershipPlan {
  id           Int      @id @default(autoincrement())
  companyId    Int      @map("company_id")
  company      Company  @relation(fields: [companyId], references: [id])
  name         String
  durationDays Int      @map("duration_days")
  price        Decimal
  description  String?
  features     String?
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")

  memberships Membership[]

  @@schema("tenant")
  @@map("membership_plans")
}

model GymMember {
  id               Int             @id @default(autoincrement())
  companyId        Int             @map("company_id")
  company          Company         @relation(fields: [companyId], references: [id])
  customerId       Int             @unique @map("customer_id")
  customer         Customer        @relation(fields: [customerId], references: [id])
  emergencyContact String?         @map("emergency_contact")
  emergencyPhone   String?         @map("emergency_phone")
  birthDate        DateTime?       @map("birth_date")
  gender           String?
  bloodType        String?         @map("blood_type")
  medicalNotes     String?         @map("medical_notes")
  photoUrl         String?         @map("photo_url")
  status           GymMemberStatus @default(ACTIVE)
  createdAt        DateTime        @default(now()) @map("created_at")

  memberships       Membership[]
  checkIns          CheckIn[]
  dayPasses         DayPass[]
  classEnrollments  ClassEnrollment[]
  bodyMeasurements  BodyMeasurement[]
  lockerAssignments LockerAssignment[]

  @@unique([companyId, customerId])
  @@schema("tenant")
  @@map("gym_members")
}

model Membership {
  id            Int                     @id @default(autoincrement())
  companyId     Int                     @map("company_id")
  memberId      Int                     @map("member_id")
  member        GymMember               @relation(fields: [memberId], references: [id])
  planId        Int                     @map("plan_id")
  plan          MembershipPlan          @relation(fields: [planId], references: [id])
  startDate     DateTime                @map("start_date")
  endDate       DateTime                @map("end_date")
  status        MembershipStatus        @default(ACTIVE)
  paymentStatus MembershipPaymentStatus @default(PENDING) @map("payment_status")
  invoiceId     Int?                    @map("invoice_id")
  notes         String?
  createdAt     DateTime                @default(now()) @map("created_at")

  @@schema("tenant")
  @@map("memberships")
}

model CheckIn {
  id        Int           @id @default(autoincrement())
  companyId Int           @map("company_id")
  memberId  Int           @map("member_id")
  member    GymMember     @relation(fields: [memberId], references: [id])
  timestamp DateTime      @default(now())
  type      CheckInType
  method    CheckInMethod
  dayPassId Int?          @map("day_pass_id")
  notes     String?

  @@schema("tenant")
  @@map("check_ins")
}

model DayPass {
  id           Int           @id @default(autoincrement())
  companyId    Int           @map("company_id")
  company      Company       @relation(fields: [companyId], references: [id])
  memberId     Int?          @map("member_id")
  member       GymMember?    @relation(fields: [memberId], references: [id])
  guestName    String?       @map("guest_name")
  date         DateTime      @default(now())
  price        Decimal
  totalEntries Int           @default(1) @map("total_entries")
  usedEntries  Int           @default(0) @map("used_entries")
  status       DayPassStatus @default(ACTIVE)
  invoiceId    Int?          @map("invoice_id")
  createdAt    DateTime      @default(now()) @map("created_at")

  @@schema("tenant")
  @@map("day_passes")
}

model GymClass {
  id          Int      @id @default(autoincrement())
  companyId   Int      @map("company_id")
  company     Company  @relation(fields: [companyId], references: [id])
  name        String
  description String?
  trainerId   Int?     @map("trainer_id")
  trainer     User?    @relation(fields: [trainerId], references: [id])
  dayOfWeek   Int      @map("day_of_week")
  startTime   String   @map("start_time")
  endTime     String   @map("end_time")
  maxCapacity Int      @default(20) @map("max_capacity")
  room        String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  enrollments ClassEnrollment[]

  @@schema("tenant")
  @@map("gym_classes")
}

model ClassEnrollment {
  id        Int                   @id @default(autoincrement())
  companyId Int                   @map("company_id")
  memberId  Int                   @map("member_id")
  member    GymMember             @relation(fields: [memberId], references: [id])
  classId   Int                   @map("class_id")
  gymClass  GymClass              @relation(fields: [classId], references: [id])
  date      DateTime
  status    ClassEnrollmentStatus @default(ENROLLED)

  @@schema("tenant")
  @@map("class_enrollments")
}

model BodyMeasurement {
  id           Int       @id @default(autoincrement())
  companyId    Int       @map("company_id")
  memberId     Int       @map("member_id")
  member       GymMember @relation(fields: [memberId], references: [id])
  date         DateTime  @default(now())
  weight       Decimal?
  height       Decimal?
  bodyFat      Decimal?  @map("body_fat")
  chest        Decimal?
  waist        Decimal?
  hips         Decimal?
  leftArm      Decimal?  @map("left_arm")
  rightArm     Decimal?  @map("right_arm")
  leftThigh    Decimal?  @map("left_thigh")
  rightThigh   Decimal?  @map("right_thigh")
  notes        String?
  measuredById Int?      @map("measured_by_id")
  measuredBy   User?     @relation("MeasuredBy", fields: [measuredById], references: [id])

  @@schema("tenant")
  @@map("body_measurements")
}

model Locker {
  id        Int          @id @default(autoincrement())
  companyId Int          @map("company_id")
  company   Company      @relation(fields: [companyId], references: [id])
  number    String
  section   String?
  status    LockerStatus @default(AVAILABLE)

  assignments LockerAssignment[]

  @@unique([companyId, number])
  @@schema("tenant")
  @@map("lockers")
}

model LockerAssignment {
  id         Int       @id @default(autoincrement())
  companyId  Int       @map("company_id")
  lockerId   Int       @map("locker_id")
  locker     Locker    @relation(fields: [lockerId], references: [id])
  memberId   Int       @map("member_id")
  member     GymMember @relation(fields: [memberId], references: [id])
  startDate  DateTime  @map("start_date")
  endDate    DateTime? @map("end_date")
  monthlyFee Decimal   @default(0) @map("monthly_fee")

  @@schema("tenant")
  @@map("locker_assignments")
}
